# Copy: cp .env.example .env
# KHÔNG commit .env lên git

# Mật khẩu root ArangoDB — phải khớp configs/PRO-database-configs.json → password
ARANGO_ROOT_PASSWORD=mat_khau_root_arangodb

# Key trong configs/http-routing-configs.json (truyền vào java -jar ... <key>)
HTTP_ROUTER_KEY=leocdp_admin1
HTTP_ROUTER_KEY1=datahub1

# Job name cho scheduler (mặc định khớp start-data-connector-jobs.sh)
SCHEDULER_JOB_NAME=DataConnectorScheduler

# Chỉ dùng khi chạy: docker compose --profile jobs up -d
# Giá trị hợp lệ: LeoCdpEventProcessingJob | LeoCdpProfileProcessingJob
CONNECTOR_JOB_NAME=LeoCdpEventProcessingJob
